var STAT_NAMES = ["Range", "Stability", "Handling", "Reload", "Aim Assist", "Zoom",
  "Magazine", "Blast Radius", "Velocity", "Charge Time", "Draw Time", "Swing Speed"];

// Column layout on "Best Rolls": A Weapon Type, B Frame, C Examples,
// D Barrel, E Magazine, F Perk1, G Perk2, H Origin, I Priority Stats,
// J Submitted By, K Notes, L _Key (hidden helper).
var COLS = { barrels: 4, magazines: 5, perks1: 6, perks2: 7, origins: 8, key: 12 };

function fixDropdowns() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Best Rolls");
  if (!sheet) throw new Error('No "Best Rolls" sheet found - check the tab name.');
  var lastRow = sheet.getLastRow();
  var keys = sheet.getRange(2, COLS.key, lastRow - 1, 1).getValues();

  var statRule = SpreadsheetApp.newDataValidation().requireValueInList(STAT_NAMES, true).setAllowInvalid(true).build();
  sheet.getRange(2, 9, lastRow - 1, 1).setDataValidation(statRule);

  var fixed = 0, skipped = [];
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i][0];
    var row = i + 2;
    var pool = POOLS[key];
    if (!pool) { skipped.push(row); continue; }
    ["barrels", "magazines", "perks1", "perks2", "origins"].forEach(function (col) {
      var values = pool[col];
      if (!values || values.length === 0) return;
      var rule = SpreadsheetApp.newDataValidation().requireValueInList(values, true).setAllowInvalid(true).build();
      sheet.getRange(row, COLS[col]).setDataValidation(rule);
    });
    fixed++;
  }
  Logger.log('Fixed ' + fixed + ' rows.' + (skipped.length ? ' No matching key for rows: ' + skipped.join(', ') : ''));
}
