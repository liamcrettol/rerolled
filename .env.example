# NextAuth
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Bungie API - from bungie.net/en/Application
BUNGIE_API_KEY=
BUNGIE_CLIENT_ID=
BUNGIE_CLIENT_SECRET=
# OAuth redirect URL (optional - defaults to NEXTAUTH_URL/api/auth/bungie/callback)
BUNGIE_REDIRECT_URI=

# Supabase - from supabase.com project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (for migrations) - from Supabase project settings > Database
DATABASE_URL=

# 32-byte hex key for encrypting stored OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Shared secret for the cron endpoints (GitHub Actions send it as a Bearer token).
# Required in production - the cron routes reject requests without it there.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Appwrite - raw PGCR archive (see docs/pgcr-archive.md). Server-only: never
# prefix any of these with NEXT_PUBLIC_, and never grant the API key more than
# Storage read/write on the pgcr-archive bucket.
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_PGCR_BUCKET_ID=pgcr-archive
APPWRITE_API_KEY=

# PGCR archive rollout flags - all default OFF ("1" to enable, anything else
# is treated as disabled). See docs/pgcr-archive.md for the safe rollout order.
PGCR_ARCHIVE_READS=
PGCR_ARCHIVE_WRITES=
PGCR_ARCHIVE_CLEAR_VERIFIED=
